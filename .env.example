NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:1234@localhost:5432/pasturas_gutierrez

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# ==========================
# Files module
# ==========================
# driver activo: remote | s3
FILES_DRIVER=remote

FILES_MAX_BYTES=15728640
FILES_ALLOWED_MIME=application/pdf,image/png,image/jpeg,image/webp

# Con esto nos conectamos al buket de s3 remoto (puede ser tu propio microservicio o un servicio externo tipo Filestack, Uploadcare, etc)
FILES_API_BASE=https://7qk35vr9qe.us-east-2.awsapprunner.com
FILES_API_KEY=84299eb2c8eb698839548ccea6d0c51ee8377037313c09c2334b978ed759d322
FILES_TENANT_KEY=trazabilidad-vasquetto
FILES_CDN_BASE=https://do9qye4wpxqu6.cloudfront.net

# compat legacy (si hay proyectos viejos)
IMAGES_API_BASE=
IMAGES_API_KEY=
IMAGES_TENANT_KEY=
IMAGES_CLOUDFRONT_BASE=


# ==========================
# JWT
# ==========================
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d



# Audit
AUDIT_RETENTION_DAYS=90
AUDIT_CLEANUP_CRON=0 3 * * *


# Seed admin
SEED_ADMIN_EMAIL=admin@innoview.local
SEED_ADMIN_PASSWORD=admin123
SEED_TENANT_ID=00000000-0000-0000-0000-000000000001

TENANCY_ENABLED=true
TENANCY_HEADER=x-tenant-id   # o x-tenant-key (como tus servicios)
TENANCY_REQUIRED=false       # si true: 400 si no viene tenant





# ==========================
# Security base
# ==========================
# Body limits (JSON / urlencoded)
BODY_LIMIT=1mb

# Helmet
HELMET_ENABLED=true

# CORS
CORS_ENABLED=true
# Separado por comas. Si vacío, en dev permite todo.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=false

# Rate limit (global)
THROTTLE_TTL=60
THROTTLE_LIMIT=300



# ==========================
# Observability
# ==========================
SERVICE_NAME=api

# Metrics
METRICS_ENABLED=true

# OpenTelemetry (Tracing)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=api
# Ej: http://localhost:4318/v1/traces  (Grafana Tempo / OTEL collector)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry (Alertas / Error tracking)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0


